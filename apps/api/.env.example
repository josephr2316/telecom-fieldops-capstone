NODE_ENV=development
PORT=3000

# Legacy/shared secret (compatibility)
JWT_SECRET=change-this-legacy-secret

# Preferred token secrets
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret

JWT_ISSUER=telecom-fieldops-api
JWT_AUDIENCE=telecom-fieldops-clients

BCRYPT_ROUNDS=10

# CORS: set in production so the frontend can call the API (e.g. Railway + Vercel).
# FRONTEND_URL=https://your-app.vercel.app
# API_PUBLIC_URL=https://your-api.up.railway.app

# Database: main app DB is "capstone". Use it in DATABASE_URL and DIRECT_URL.
# On first deploy (e.g. Railway): run "npm run migrate" then "npm run seed" so tables and users exist.
# Pooler (port 6543) for app runtime.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/capstone?pgbouncer=true&sslmode=require
# Direct (port 5432) to capstone – used by Prisma for migrate deploy / status (creates and tracks tables here).
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/capstone?sslmode=require
# Optional: second database (e.g. "store") used only by `prisma migrate dev` as shadow. Not used by the app nor by migrate deploy.
# SHADOW_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/store?sslmode=require
