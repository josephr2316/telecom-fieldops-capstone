{
  "name": "telecom-fieldops-api",
  "version": "1.0.0",
  "description": "API FieldOps Telecom - operations, inventory, work orders",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive: true})\" && node -e \"require('fs').mkdirSync('dist/openapi', {recursive: true}); require('fs').copyFileSync('src/openapi/openapi.yaml', 'dist/openapi/openapi.yaml')\"",
    "postinstall": "prisma generate",
    "start": "node dist/main.js",
    "release": "npx prisma migrate deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "npx prisma migrate deploy",
    "migrate:diff": "npx prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --script",
    "openapi:validate": "node ../../scripts/validate-openapi.js src/openapi/openapi.yaml",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "prisma": {
    "seed": "ts-node --transpile-only -r dotenv/config prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dompurify": "^3.2.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
